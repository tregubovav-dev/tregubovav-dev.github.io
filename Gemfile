# Gemfile for a Jekyll site under a restricted user
source "https://rubygems.org"

# Use a standard theme from RubyGems
gem "minima", git: "https://github.com/jekyll/minima.git", ref: "bf9ef98"

# The Jekyll core and common plugins
gem "jekyll", "~> 3.9"
gem "base64"
gem "bigdecimal"
gem "kramdown-parser-gfm"
gem "jekyll-remote-theme"

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.12"
  gem "jekyll-seo-tag"
  gem "jekyll-remote-theme"
end
